rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    match /productos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /repuestos/{id} {
      allow read, write: if isSignedIn();
    }
    match /ordenesVenta/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /ordenesReparacion/{id} {
      allow read, write: if isSignedIn();
    }
    match /usuarios/{id} {
      allow read, write: if isSignedIn();
    }
    match /configuracion/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /movimientosInventario/{id} {
      allow read, write: if isSignedIn();
    }
    match /historicalSKUs/{id} {
      allow read, write: if isSignedIn();
    }
    
    // Legacy maps
    match /chat_conversations/{id} { allow read, write: if true; }
    match /empleados/{id} { allow read, write: if isSignedIn(); }
    match /payroll/{id} { allow read, write: if isSignedIn(); }
    match /audit_log/{id} { allow read, write: if isSignedIn(); }
    match /clients/{id} { allow read, write: if true; }
    match /deliveries/{id} { allow read, write: if isSignedIn(); }
    match /marketing_campaigns/{id} { allow read, write: if isSignedIn(); }
    match /banners/{id} { allow read, write: if true; }
    match /globals/{id} { allow read, write: if true; }
    match /membership_tiers/{id} { allow read, write: if true; }
  }
}
