rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is admin (Dueño)
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'technoverse.admin@gmail.com';
    }
    
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
